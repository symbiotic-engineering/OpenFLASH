@article{kokkinowrachos_behaviour_1986,
	title = {Behaviour of vertical bodies of revolution in waves},
	volume = {13},
	issn = {0029-8018},
	url = {https://www.sciencedirect.com/science/article/pii/0029801886900375},
	doi = {10.1016/0029-8018(86)90037-5},
	abstract = {This paper presents the so-called macroelement method by means of which the complete linear hydromechanic analysis of arbitrarily shaped bodies of revolution with vertical axis can be carried out. The development of a special method for this wide class of structures which are common in offshore designs is of great advantage for the engineering work. The method described here is based on the discretization of the flow field around the structure by means of ring-shaped macroelements, the velocity potential in each element being approximated with Fourier series. For the matching of the solution between neighbouring elements Galerkin's method is applied. Both the diffraction and the radiation problems are solved.},
	number = {6},
	urldate = {2023-12-12},
	journal = {Ocean Engineering},
	author = {Kokkinowrachos, Konstantin and Mavrakos, Spyridon and Asorakos, Sampson},
	month = jan,
	year = {1986},
	pages = {505--538},
}

